{
  "name": "restaurant-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "tsc -b --pretty false",
    "preview": "vite preview",
    "test:e2e": "VITE_WORKOS_CLIENT_ID= npm run build && playwright test --grep-invert @authenticated",
    "test:e2e:authenticated": "playwright test --grep @authenticated",
    "install:e2e": "playwright install chromium"
  },
  "dependencies": {
    "@workos-inc/authkit-react": "^0.16.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.3.0"
  }
}
