DATABASE_URL=postgres://restaurant:restaurant@localhost:5432/restaurant
API_HOST=0.0.0.0
API_PORT=8080
WEB_ORIGIN=http://localhost:5173
RUST_LOG=restaurant_api=debug,tower_http=debug

# AuthKit SPA tokens scope both the issuer and JWKS URL to the WorkOS client ID.
WORKOS_ISSUER=https://api.workos.com/user_management/client_your_client_id
WORKOS_JWKS_URL=https://api.workos.com/sso/jwks/client_your_client_id
# Optional server-side key. When omitted, the API starts with team invitations disabled.
# Configure WorkOS AuthKit's default invitation/accept URL before enabling this.
# WORKOS_API_KEY=sk_your_server_api_key

# Added with the invoice upload flow.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Gemini paid tier is required for real invoices. This stable model name is stored with each extraction.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
